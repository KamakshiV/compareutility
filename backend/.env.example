# Local Docker Postgres (default dev)
DATABASE_URL=postgresql+asyncpg://compare:compare@127.0.0.1:5433/reconiq

# Supabase (production): use the dashboard URI but switch to asyncpg + SSL, e.g.
# DATABASE_URL=postgresql+asyncpg://postgres:ENCODED_PASSWORD@db.xxxxx.supabase.co:5432/postgres?ssl=require

STORAGE_LOCAL_PATH=./data/storage

# Browser CORS: must list the exact origin of the UI (scheme + host + port). Comma-separated.
# If the browser shows "Failed to fetch" on upload/compare, the backend is unreachable or CORS blocked.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,https://your-app.vercel.app

# Optional Azure Blob
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_CONTAINER_NAME=comparisons

# Optional LLM summary (requires OpenAI or Azure OpenAI env below)
USE_LLM_SUMMARY=false
# Structured LLM discrepancy identification (JSON + PDF section 2); independent of USE_LLM_SUMMARY
USE_LLM_DISCREPANCY_IDENTIFICATION=false
OPENAI_API_KEY=

# Azure OpenAI (when set, Azure path is used)
# OPENAI_API_BASE=https://your-resource.openai.azure.com/
# OPENAI_API_VERSION=2024-08-01-preview
# OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
